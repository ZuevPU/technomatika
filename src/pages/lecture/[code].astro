---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { path } from '../../utils/paths';

export async function getStaticPaths() {
  const lectures = await getCollection('lectures');
  return lectures.map(lecture => ({
    params: { code: lecture.data.code.replace('.', '-') },
    props: { lecture },
  }));
}

const { lecture } = Astro.props;
const { data } = lecture;
const { Content } = await lecture.render();

// Build sorted list for prev/next navigation
const allLectures = await getCollection('lectures');
const sorted = allLectures.sort((a, b) => a.data.code.localeCompare(b.data.code));
const idx = sorted.findIndex(l => l.data.code === data.code);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

const iconMap = {
  pdf: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="14" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M5 5h6M5 7.5h6M5 10h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>`,
  link: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6.5 9.5l3-3M9 4.5l1.5-1.5a2.12 2.12 0 013 3L12 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M7 11.5l-1.5 1.5a2.12 2.12 0 01-3-3L4 8.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>`,
  video: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="3" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M11 5.5l4 2.5-4 2.5V5.5z" fill="currentColor"/></svg>`,
  file: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1v5h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M13 6L8 1H3a1 1 0 00-1 1v12a1 1 0 001 1h10a1 1 0 001-1V6z" stroke="currentColor" stroke-width="1.3"/></svg>`,
};
---

<Layout
  title={`${data.code} ${data.title} — ТЕХНОМАТИКА`}
  description={data.summary}
>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-16">

    <!-- Breadcrumbs -->
    <nav aria-label="Хлебные крошки" class="mb-6 md:mb-8">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted">
        <li><a href={path('/')} class="hover:text-ink transition-colors">Главная</a></li>
        <li aria-hidden="true"><span class="text-line">/</span></li>
        <li>
          <a href={path('/#modules')} class="hover:text-ink transition-colors">
            Модуль {data.module}
          </a>
        </li>
        <li aria-hidden="true"><span class="text-line">/</span></li>
        <li aria-current="page" class="text-ink font-medium">{data.code}</li>
      </ol>
    </nav>

    <!-- Lecture header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="chip-green">{data.code}</span>
        <span class="text-sm text-muted">Модуль {data.module} · {data.moduleTitle}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-ink leading-tight mb-4" style="letter-spacing: -0.01em;">
        {data.title}
      </h1>
      <p class="text-muted text-base leading-relaxed max-w-2xl">{data.summary}</p>

      <div class="flex flex-wrap gap-4 mt-6 pt-6 border-t border-line">
        {data.practiceTitle && (
          <div class="flex items-center gap-2 text-sm text-muted">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5 8h6M5 5.5h6M5 10.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            {data.practiceTitle}
          </div>
        )}
      </div>
    </header>

    <!-- Materials block -->
    <section class="mb-12 p-6 md:p-8 rounded-card border border-line bg-white" aria-labelledby="materials-heading">
      <h2 id="materials-heading" class="text-lg font-semibold text-ink mb-5">
        Материалы лекции
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Slides -->
        {data.slidesUrl ? (
          <a
            href={path(data.slidesUrl)}
            {...(data.slidesUrl.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="material-card material-card--active"
          >
            <div class="material-icon bg-brand-green text-ink">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="2" y="3" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7.5 7.5l4 2.5-4 2.5V7.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-sm text-ink">Презентация</div>
              <div class="text-xs text-muted mt-0.5">Открыть слайды →</div>
            </div>
          </a>
        ) : (
          <div class="material-card material-card--soon" aria-disabled="true">
            <div class="material-icon bg-line text-muted">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="2" y="3" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7.5 7.5l4 2.5-4 2.5V7.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-sm text-muted">Презентация</div>
              <div class="soon-tag mt-1">Скоро</div>
            </div>
          </div>
        )}

        <!-- Transcript -->
        {data.transcriptUrl ? (
          <a
            href={path(data.transcriptUrl)}
            {...(data.transcriptUrl.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="material-card material-card--active"
          >
            <div class="material-icon bg-brand-green text-ink">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 4h14M3 7.5h14M3 11h10M3 14.5h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-sm text-ink">{data.transcriptLabel ?? 'Конспект лекции'}</div>
              <div class="text-xs text-muted mt-0.5">
                {data.transcriptUrl?.startsWith('http') ? 'Открыть конструктор →' : 'Открыть текст →'}
              </div>
            </div>
          </a>
        ) : data.module !== 3 ? (
          <div class="material-card material-card--soon" aria-disabled="true">
            <div class="material-icon bg-line text-muted">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 4h14M3 7.5h14M3 11h10M3 14.5h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-sm text-muted">Конспект лекции</div>
              <div class="soon-tag mt-1">Скоро</div>
            </div>
          </div>
        ) : null}
      </div>

      <!-- Extra materials list -->
      {data.materials.length > 0 && (
        <div class="mt-6 pt-6 border-t border-line">
          <h3 class="text-sm font-semibold text-ink uppercase tracking-widest mb-4">Полезные материалы</h3>
          <ul class="flex flex-col gap-3">
            {data.materials.map(mat => (
              <li>
                <a
                  href={mat.url}
                  {...(mat.url.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="flex items-center gap-3 text-sm text-ink hover:text-brand-dark transition-colors group"
                >
                  <span class="text-muted group-hover:text-ink transition-colors" set:html={iconMap[mat.type]} />
                  <span class="group-hover:underline">{mat.title}</span>
                  <span class="text-muted text-xs uppercase ml-auto">{mat.type}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <!-- Lecture content (markdown) -->
    {data.materials.length > 0 && (
      <article class="prose prose-neutral max-w-none mb-16">
        <Content />
      </article>
    )}

    <!-- Prev / Next navigation -->
    <nav class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-8 border-t border-line" aria-label="Навигация по темам">
      {prev ? (
        <a
          href={path(`/lecture/${prev.data.code.replace('.', '-')}`)}
          class="nav-adjacent nav-adjacent--prev"
        >
          <span class="text-xs text-muted mb-1">← Предыдущая тема</span>
          <span class="font-semibold text-sm text-ink">{prev.data.code} {prev.data.title}</span>
        </a>
      ) : <div />}

      {next && (
        <a
          href={path(`/lecture/${next.data.code.replace('.', '-')}`)}
          class="nav-adjacent nav-adjacent--next sm:text-right"
        >
          <span class="text-xs text-muted mb-1">Следующая тема →</span>
          <span class="font-semibold text-sm text-ink">{next.data.code} {next.data.title}</span>
        </a>
      )}
    </nav>

  </div>
</Layout>

<style>
  .chip-green {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: #7CC142;
    color: #111312;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .material-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px;
    border-radius: 10px;
    border: 1.5px solid var(--line);
    text-decoration: none;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .material-card--active {
    cursor: pointer;
  }
  .material-card--active:hover {
    border-color: #111312;
    box-shadow: 0 4px 16px rgba(17,19,18,0.10);
  }
  .material-card--active:focus-visible {
    outline: 2px solid #111312;
    outline-offset: 2px;
  }
  .material-card--soon {
    cursor: not-allowed;
    opacity: 0.65;
  }
  .material-icon {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .soon-tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 7px;
    background: #E6E6E3;
    color: #6B6F6E;
    font-size: 11px;
    font-weight: 600;
    border-radius: 4px;
  }

  .nav-adjacent {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 16px 18px;
    min-height: 68px;
    border: 1.5px solid var(--line);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    touch-action: manipulation;
  }
  .nav-adjacent:hover {
    border-color: #111312;
    box-shadow: 0 2px 12px rgba(17,19,18,0.08);
  }
  .nav-adjacent:focus-visible {
    outline: 2px solid #111312;
    outline-offset: 2px;
  }

  /* Prose styles */
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #111312;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .prose h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: #111312;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    color: #111312;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose ul {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1rem;
  }
  .prose ul li {
    padding-left: 1.5rem;
    position: relative;
    color: #111312;
    line-height: 1.7;
    margin-bottom: 0.4rem;
  }
  .prose ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    background: #7CC142;
    transform: skewX(-15deg);
  }
  .prose strong {
    font-weight: 600;
    color: #111312;
  }
  .prose code {
    background: #f5f5f3;
    padding: 2px 5px;
    border-radius: 4px;
    font-size: 0.875em;
  }
</style>
