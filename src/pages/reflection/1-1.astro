---
import Layout from '../../layouts/Layout.astro';
import { path } from '../../utils/paths';
import {
  REFLECTION_META,
  SCALES,
  CONCLUSIONS,
} from '../../data/reflection-1-1';

const scalesJson = JSON.stringify(SCALES);
const conclusionsJson = JSON.stringify(CONCLUSIONS);
const metaJson = JSON.stringify(REFLECTION_META);
---

<Layout
  title="Рефлексия 1.1 — Самодиагностика междисциплинарной практики — ТЕХНОМАТИКА"
  description="Интерактивный тренажёр: 10 шкал по тезисам лекции, диаграмма-паутинка и персональный вывод для учителя."
>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-16" id="reflection-app">

    <nav aria-label="Хлебные крошки" class="mb-6 md:mb-8">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted">
        <li><a href={path('/')} class="hover:text-ink transition-colors">Главная</a></li>
        <li aria-hidden="true"><span class="text-line">/</span></li>
        <li>
          <a href={path('/lecture/1-1')} class="hover:text-ink transition-colors">1.1</a>
        </li>
        <li aria-hidden="true"><span class="text-line">/</span></li>
        <li>
          <a href={path('/transcript/1-1')} class="hover:text-ink transition-colors">Конспект</a>
        </li>
        <li aria-hidden="true"><span class="text-line">/</span></li>
        <li aria-current="page" class="text-ink font-medium">Рефлексия</li>
      </ol>
    </nav>

    <!-- INTRO -->
    <section id="step-intro" class="step" data-step="intro">
      <p class="eyebrow">Рефлексия · тема 1.1</p>
      <h1 class="page-title">{REFLECTION_META.introTitle}</h1>
      <div class="intro-body space-y-4 mb-8">
        {REFLECTION_META.introBody.map((p) => (
          <p class="body-text">{p}</p>
        ))}
        <p class="body-text">
          По итогам появится диаграмма-паутинка и короткий вывод: что уже опирается на сильные стороны и что стоит усилить в ближайшей работе.
        </p>
      </div>

      <div class="zone-legend mb-10" aria-label="Зоны шкалы">
        <div class="zone-chip zone-chip--gap">
          <span class="zone-dot"></span>
          0–3 · Расхождение
        </div>
        <div class="zone-chip zone-chip--transition">
          <span class="zone-dot"></span>
          4–7 · Переход
        </div>
        <div class="zone-chip zone-chip--anchor">
          <span class="zone-dot"></span>
          8–10 · Опора
        </div>
      </div>

      <button type="button" class="btn-primary" id="btn-start">
        Начать диагностику
      </button>
    </section>

    <!-- SCALES -->
    <section id="step-scales" class="step hidden" data-step="scales" hidden>
      <div class="scales-top mb-6">
        <div class="flex items-end justify-between gap-4 mb-3">
          <p class="eyebrow mb-0">Шкала <span id="scale-num">1</span> из 10</p>
          <p class="text-sm text-muted tabular-nums" id="scale-value-label">5</p>
        </div>
        <div class="progress-track" aria-hidden="true">
          <div class="progress-fill" id="progress-fill" style="width: 10%"></div>
        </div>
      </div>

      <article class="scale-card" id="scale-card">
        <p class="scale-axis" id="scale-axis"></p>
        <h2 class="scale-title" id="scale-title"></h2>
        <p class="scale-thesis" id="scale-thesis"></p>
        <p class="scale-question" id="scale-question"></p>

        <div class="slider-block">
          <div class="poles">
            <p class="pole pole--0" id="pole-0"></p>
            <p class="pole pole--10" id="pole-10"></p>
          </div>

          <div class="slider-wrap">
            <div class="slider-zones" aria-hidden="true">
              <span class="sz sz-gap"></span>
              <span class="sz sz-transition"></span>
              <span class="sz sz-anchor"></span>
            </div>
            <input
              type="range"
              id="scale-slider"
              min="0"
              max="10"
              step="1"
              value="5"
              aria-valuemin="0"
              aria-valuemax="10"
              aria-valuenow="5"
              aria-label="Оценка по шкале от 0 до 10"
            />
            <div class="slider-ticks" aria-hidden="true">
              {Array.from({ length: 11 }, (_, i) => (
                <span>{i}</span>
              ))}
            </div>
          </div>

          <p class="zone-live" id="zone-live">Переход: ещё не закреплено</p>
          <p class="slider-hint">Перетащите к тому полюсу, который ближе к вашей реальной практике</p>
          <details class="hint-details">
            <summary>Подсказка к честной оценке</summary>
            <p id="scale-hint"></p>
          </details>
        </div>
      </article>

      <div class="nav-row">
        <button type="button" class="btn-ghost" id="btn-prev" disabled>← Назад</button>
        <button type="button" class="btn-primary" id="btn-next">Далее →</button>
      </div>
    </section>

    <!-- RESULT -->
    <section id="step-result" class="step hidden" data-step="result" hidden>
      <p class="eyebrow">Ваш профиль</p>
      <h1 class="page-title page-title--sm">Диаграмма и вывод</h1>
      <p class="result-sub">Десять идей лекции — один снимок вашей практики</p>

      <div class="result-hero mb-8">
        <div class="result-mean">
          <span class="mean-label">Средний балл</span>
          <span class="mean-value" id="mean-value">—</span>
          <span class="mean-hint">из 10</span>
        </div>

        <div class="radar-wrap" role="img" aria-label="Диаграмма-паутинка по десяти шкалам">
          <svg id="radar-svg" viewBox="0 0 480 480" class="radar-svg" aria-hidden="true"></svg>
          <div class="radar-legend">
            <span class="radar-legend-item"><i class="lg-ref"></i> Опора · 8</span>
            <span class="radar-legend-item"><i class="lg-you"></i> Ваш профиль</span>
          </div>
        </div>
      </div>

      <section class="profile-table-block mb-10" aria-labelledby="profile-table-title">
        <div class="profile-table-intro">
          <h2 id="profile-table-title" class="profile-table-title">Ваши баллы</h2>
          <p class="profile-table-desc">
            <span class="hint-gap">0–3 слабо</span>
            <span class="hint-mid">4–7 переход</span>
            <span class="hint-ok">8–10 опора</span>
          </p>
        </div>

        <div class="score-list" id="axis-list"></div>
      </section>

      <article class="conclusion-card" id="conclusion-card">
        <p class="conclusion-badge" id="conclusion-badge"></p>
        <h2 class="conclusion-title" id="conclusion-title"></h2>
        <p class="body-text" id="conclusion-lead"></p>
        <div class="conclusion-tags mt-5">
          <div class="tag-card tag-card--strong">
            <p class="tag-label" id="strong-label">Опереться на</p>
            <p class="tag-value" id="strong-value"></p>
          </div>
          <div class="tag-card tag-card--grow">
            <p class="tag-label" id="grow-label">Усилить</p>
            <p class="tag-value" id="grow-value"></p>
          </div>
        </div>
        <h3 class="actions-title" id="actions-title"></h3>
        <ol class="actions-list" id="actions-list"></ol>
        <p class="body-text conclusion-closing" id="conclusion-closing"></p>
      </article>

      <div class="nav-row mt-10">
        <button type="button" class="btn-ghost" id="btn-restart">Пройти ещё раз</button>
        <a href={path('/transcript/1-1')} class="btn-primary btn-link">← К конспекту</a>
      </div>
    </section>

  </div>
</Layout>

<script
  define:vars={{
    scalesJson,
    conclusionsJson,
    metaJson,
  }}
>
  const SCALES = JSON.parse(scalesJson);
  const CONCLUSIONS = JSON.parse(conclusionsJson);
  const META = JSON.parse(metaJson);

  const values = Array(SCALES.length).fill(5);
  let step = 'intro';
  let index = 0;

  const els = {
    intro: document.getElementById('step-intro'),
    scales: document.getElementById('step-scales'),
    result: document.getElementById('step-result'),
    scaleNum: document.getElementById('scale-num'),
    scaleValueLabel: document.getElementById('scale-value-label'),
    progressFill: document.getElementById('progress-fill'),
    axis: document.getElementById('scale-axis'),
    title: document.getElementById('scale-title'),
    thesis: document.getElementById('scale-thesis'),
    question: document.getElementById('scale-question'),
    pole0: document.getElementById('pole-0'),
    pole10: document.getElementById('pole-10'),
    hint: document.getElementById('scale-hint'),
    slider: document.getElementById('scale-slider'),
    zoneLive: document.getElementById('zone-live'),
    btnPrev: document.getElementById('btn-prev'),
    btnNext: document.getElementById('btn-next'),
    btnStart: document.getElementById('btn-start'),
    btnRestart: document.getElementById('btn-restart'),
    meanValue: document.getElementById('mean-value'),
    radarSvg: document.getElementById('radar-svg'),
    axisList: document.getElementById('axis-list'),
    conclusionBadge: document.getElementById('conclusion-badge'),
    conclusionTitle: document.getElementById('conclusion-title'),
    conclusionLead: document.getElementById('conclusion-lead'),
    strongLabel: document.getElementById('strong-label'),
    strongValue: document.getElementById('strong-value'),
    growLabel: document.getElementById('grow-label'),
    growValue: document.getElementById('grow-value'),
    actionsTitle: document.getElementById('actions-title'),
    actionsList: document.getElementById('actions-list'),
    conclusionClosing: document.getElementById('conclusion-closing'),
  };

  function zoneFor(v) {
    if (v <= 3) return 'gap';
    if (v <= 7) return 'transition';
    return 'anchor';
  }

  function zoneLabel(zone) {
    if (zone === 'gap') return 'Расхождение с идеей';
    if (zone === 'transition') return 'Переход: ещё не закреплено';
    return 'Опора в практике';
  }

  function showStep(name) {
    step = name;
    [els.intro, els.scales, els.result].forEach((el) => {
      const active = el.dataset.step === name;
      el.classList.toggle('hidden', !active);
      el.hidden = !active;
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderScale() {
    const s = SCALES[index];
    const v = values[index];
    els.scaleNum.textContent = String(index + 1);
    els.progressFill.style.width = `${((index + 1) / SCALES.length) * 100}%`;
    els.axis.textContent = s.axis;
    els.title.textContent = s.title;
    els.thesis.textContent = s.thesis;
    els.question.textContent = s.question;
    els.pole0.textContent = s.pole0;
    els.pole10.textContent = s.pole10;
    els.hint.textContent = s.hint;
    els.slider.value = String(v);
    els.slider.setAttribute('aria-valuenow', String(v));
    updateValueUI(v);
    els.btnPrev.disabled = index === 0;
    els.btnNext.textContent = index === SCALES.length - 1 ? 'Показать результат →' : 'Далее →';
  }

  function updateValueUI(v) {
    const zone = zoneFor(v);
    els.scaleValueLabel.textContent = String(v);
    els.zoneLive.textContent = zoneLabel(zone);
    els.zoneLive.dataset.zone = zone;
    els.slider.style.setProperty('--pct', `${(v / 10) * 100}%`);
  }

  function meanScore(arr) {
    const sum = arr.reduce((a, b) => a + b, 0);
    return Math.round((sum / arr.length) * 10) / 10;
  }

  function pickConclusion(mean) {
    if (mean <= 3.9) return CONCLUSIONS[0];
    if (mean <= 7.4) return CONCLUSIONS[1];
    return CONCLUSIONS[2];
  }

  function topAxes(predicate, limit = 2) {
    return SCALES.map((scale, i) => ({ axis: scale.axis, value: values[i] }))
      .filter((item) => predicate(item.value))
      .sort((a, b) => Math.abs(b.value - 5) - Math.abs(a.value - 5))
      .slice(0, limit)
      .map((item) => item.axis);
  }

  function formatAxes(list, empty) {
    if (!list.length) return empty;
    return list.join(', ');
  }

  function drawRadar(arr) {
    const size = 480;
    const cx = size / 2;
    const cy = size / 2;
    const maxR = 128;
    const n = arr.length;
    const angleStep = (Math.PI * 2) / n;
    const start = -Math.PI / 2;

    const pointAt = (i, r) => {
      const a = start + i * angleStep;
      return [cx + Math.cos(a) * r, cy + Math.sin(a) * r];
    };

    const defs = `
      <defs>
        <radialGradient id="radarFill" cx="50%" cy="50%" r="65%">
          <stop offset="0%" stop-color="#7CC142" stop-opacity="0.38"/>
          <stop offset="70%" stop-color="#7CC142" stop-opacity="0.16"/>
          <stop offset="100%" stop-color="#34C759" stop-opacity="0.05"/>
        </radialGradient>
        <filter id="softGlow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3.5" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <filter id="dotShadow" x="-50%" y="-50%" width="200%" height="200%">
          <feDropShadow dx="0" dy="1" stdDeviation="1.2" flood-color="#111312" flood-opacity="0.18"/>
        </filter>
      </defs>`;

    // Soft circular rings (Apple Fitness style)
    const rings = [0.2, 0.4, 0.6, 0.8, 1]
      .map((t, idx) => {
        const opacity = idx === 4 ? 0.22 : 0.12;
        return `<circle cx="${cx}" cy="${cy}" r="${maxR * t}" class="radar-ring" style="stroke-opacity:${opacity}" />`;
      })
      .join('');

    // Reference ring at 8/10
    const ref = `<circle cx="${cx}" cy="${cy}" r="${maxR * 0.8}" class="radar-ref" />`;

    const axes = Array.from({ length: n }, (_, i) => {
      const [x, y] = pointAt(i, maxR);
      return `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" class="radar-axis" />`;
    }).join('');

    const pts = arr.map((v, i) =>
      pointAt(i, (Math.max(0, Math.min(10, v)) / 10) * maxR)
    );
    const dataPts = pts.map((p) => p.join(',')).join(' ');
    const poly = `<polygon points="${dataPts}" class="radar-poly" filter="url(#softGlow)" />`;
    const stroke = `<polygon points="${dataPts}" class="radar-stroke" />`;

    const dots = pts
      .map(([x, y]) => {
        return `<circle cx="${x}" cy="${y}" r="5.5" class="radar-dot-halo" />
          <circle cx="${x}" cy="${y}" r="3.5" class="radar-dot" filter="url(#dotShadow)" />`;
      })
      .join('');

    const labels = SCALES.map((s, i) => {
      const [x, y] = pointAt(i, maxR + 42);
      const anchor = Math.abs(x - cx) < 14 ? 'middle' : x > cx ? 'start' : 'end';
      const dy = y < cy - 24 ? 0 : y > cy + 24 ? 4 : 3;
      // Split long labels into two lines when needed
      const words = s.axis.split(' ');
      let labelHtml;
      if (words.length >= 2 && s.axis.length > 12) {
        const mid = Math.ceil(words.length / 2);
        const l1 = words.slice(0, mid).join(' ');
        const l2 = words.slice(mid).join(' ');
        labelHtml = `<tspan x="${x}" dy="0">${l1}</tspan><tspan x="${x}" dy="11">${l2}</tspan>`;
      } else {
        labelHtml = s.axis;
      }
      return `<text x="${x}" y="${y + dy}" text-anchor="${anchor}" class="radar-label">${labelHtml}</text>`;
    }).join('');

    els.radarSvg.innerHTML = `${defs}${rings}${ref}${axes}${poly}${stroke}${dots}${labels}`;
  }

  function renderResult() {
    const mean = meanScore(values);
    const conclusion = pickConclusion(mean);
    const strong = topAxes((v) => v >= 8);
    const grow = topAxes((v) => v <= 3);

    els.meanValue.textContent = String(mean).replace('.', ',');
    drawRadar(values);

    els.axisList.innerHTML = SCALES.map((s, i) => {
      const v = values[i];
      const zone = zoneFor(v);
      return `<div class="score-row" data-zone="${zone}">
        <span class="score-row-name">${s.axis}</span>
        <span class="score-row-val">${v}</span>
      </div>`;
    }).join('');

    const badgeMap = { A: 'Точка входа', B: 'Сборка практики', C: 'Архитектор на марше' };
    els.conclusionBadge.textContent = badgeMap[conclusion.id];
    els.conclusionTitle.textContent = conclusion.title;
    els.conclusionLead.textContent = conclusion.lead.replace('{{M}}', String(mean).replace('.', ','));
    els.strongLabel.textContent = conclusion.strongLabel;
    els.growLabel.textContent = conclusion.growLabel;
    els.strongValue.textContent = formatAxes(strong, META.emptyStrong);
    els.growValue.textContent = formatAxes(grow, META.emptyGrow);
    els.actionsTitle.textContent = conclusion.actionsTitle;
    els.actionsList.innerHTML = conclusion.actions.map((a) => `<li>${a}</li>`).join('');
    els.conclusionClosing.textContent = conclusion.closing;
  }

  els.btnStart.addEventListener('click', () => {
    index = 0;
    showStep('scales');
    renderScale();
  });

  els.slider.addEventListener('input', () => {
    const v = Number(els.slider.value);
    values[index] = v;
    els.slider.setAttribute('aria-valuenow', String(v));
    updateValueUI(v);
  });

  els.btnPrev.addEventListener('click', () => {
    if (index === 0) return;
    index -= 1;
    renderScale();
  });

  els.btnNext.addEventListener('click', () => {
    if (index < SCALES.length - 1) {
      index += 1;
      renderScale();
      return;
    }
    renderResult();
    showStep('result');
  });

  els.btnRestart.addEventListener('click', () => {
    for (let i = 0; i < values.length; i++) values[i] = 5;
    index = 0;
    showStep('intro');
  });
</script>

<style>
  .hidden {
    display: none !important;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6B6F6E;
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 700;
    color: #111312;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .page-title--sm {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .body-text {
    color: #111312;
    line-height: 1.75;
    font-size: 1rem;
  }

  .zone-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .zone-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid rgba(0, 0, 0, 0.05);
    background: #f5f5f7;
    color: #1c1c1e;
  }

  .zone-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .zone-chip--gap .zone-dot { background: #FF453A; }
  .zone-chip--transition .zone-dot { background: #FF9F0A; }
  .zone-chip--anchor .zone-dot { background: #30D158; }

  .btn-primary,
  .btn-ghost,
  .btn-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.75rem 1.35rem;
    border-radius: 14px;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition: transform 0.15s, background 0.15s, box-shadow 0.15s, opacity 0.15s;
    text-decoration: none;
  }

  .btn-primary {
    background: #7CC142;
    color: #111312;
    border: none;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  .btn-primary:hover {
    box-shadow: 0 6px 20px rgba(124, 193, 66, 0.35);
  }

  .btn-ghost {
    background: #f5f5f7;
    color: #1c1c1e;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .btn-ghost:hover:not(:disabled) {
    background: #ebebed;
  }

  .btn-ghost:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .progress-track {
    height: 3px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: #30D158;
    border-radius: 999px;
    transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .scale-card {
    padding: 1.5rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 24px;
    background:
      linear-gradient(165deg, rgba(124, 193, 66, 0.07) 0%, transparent 40%),
      #fff;
    margin-bottom: 1.25rem;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.03),
      0 12px 32px rgba(17, 19, 18, 0.04);
  }

  .scale-axis {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.6rem;
    background: #f5f5f7;
    color: #636366;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.9rem;
  }

  .scale-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111312;
    letter-spacing: -0.01em;
    margin-bottom: 0.65rem;
    line-height: 1.3;
  }

  .scale-thesis {
    color: #6B6F6E;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .scale-question {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111312;
    line-height: 1.45;
    margin-bottom: 1.5rem;
  }

  .poles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  @media (min-width: 640px) {
    .poles {
      grid-template-columns: 1fr 1fr;
    }
  }

  .pole {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #1c1c1e;
    padding: 0.85rem;
    border-radius: 14px;
    background: #f5f5f7;
    border-left: 3px solid transparent;
  }

  .pole--0 { border-left-color: #FF453A; }
  .pole--10 { border-left-color: #30D158; }

  .slider-wrap {
    position: relative;
