  }
  .thesis-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #111312;
    margin-bottom: 0.65rem;
    letter-spacing: -0.01em;
  }
  .body-text {
    color: #111312;
    line-height: 1.75;
