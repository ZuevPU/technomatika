    background: #f7f7f5;
    color: #111312;
    font-size: 0.95rem;
    line-height: 1.6;
    font-style: italic;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 14px;
    border: 1.5px solid var(--line);
    border-radius: 10px;
    text-decoration: none;
    color: #111312;
