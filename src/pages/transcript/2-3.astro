  }
  .back-link:hover {
    border-color: #111312;
    box-shadow: 0 2px 12px rgba(17, 19, 18, 0.08);
  }

  .reflection-cta {
    background:
      linear-gradient(135deg, rgba(124, 193, 66, 0.14) 0%, transparent 55%),
      #fff;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    padding: 0.75rem 1.25rem;
    background: #7CC142;
