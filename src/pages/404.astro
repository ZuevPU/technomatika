---
import Layout from '../layouts/Layout.astro';
import DiamondPattern from '../components/DiamondPattern.astro';
import { path } from '../utils/paths';
---

<Layout title="404 — Страница не найдена · ТЕХНОМАТИКА">
  <section class="relative bg-brand-dark text-white overflow-hidden min-h-[70vh] flex items-center justify-center">
    <div class="absolute inset-0 opacity-40">
      <DiamondPattern variant="hero" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-dark/40 to-brand-dark pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 text-center px-4">
      <div class="text-[120px] md:text-[180px] font-bold leading-none text-brand-green select-none" aria-hidden="true">
        404
      </div>
      <h1 class="text-2xl md:text-3xl font-semibold text-white mt-2 mb-4">
        Страница не найдена
      </h1>
      <p class="text-white/50 mb-10 max-w-sm mx-auto leading-relaxed">
        Возможно, ссылка устарела или страница была перемещена.
      </p>
      <a
        href={path('/')}
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-green text-ink font-semibold rounded-lg hover:brightness-90 transition-all focus-visible:outline-2 focus-visible:outline-brand-green focus-visible:outline-offset-3"
      >
        ← На главную
      </a>
    </div>
  </section>
</Layout>
