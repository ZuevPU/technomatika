---
import Layout from '../layouts/Layout.astro';
import DiamondPattern from '../components/DiamondPattern.astro';
import LectureCard from '../components/LectureCard.astro';
import { getCollection } from 'astro:content';
import { path } from '../utils/paths';

const allLectures = await getCollection('lectures');
const byModule = (moduleNum: number) =>
  allLectures
    .filter(l => l.data.module === moduleNum)
    .sort((a, b) => a.data.code.localeCompare(b.data.code));

const modules = [
  {
    num: 1,
    title: 'Фундаментальные основы информатики',
    desc: 'Базовая концептуальная рамка курса: от природы информации до мультиагентного ИИ — фундамент осознанного педагогического проектирования цифровых решений.',
    lectures: byModule(1),
  },
  {
    num: 2,
    title: 'Методология извлечения информационных моделей',
    desc: 'Как структурировать знания, выстраивать современную архитектуру ИТ-решений и превращать данные в убедительные визуальные нарративы.',
    lectures: byModule(2),
  },
  {
    num: 3,
    title: 'Педагогическое проектирование образовательного продукта',
    desc: 'От основ проектной деятельности до готового цифрового продукта: создание вовлекающего контента и современные подходы к оцениванию.',
    lectures: byModule(3),
  },
];

const ALL_MATERIALS_URL = 'https://disk.yandex.ru/d/Qv6znPxKL8uxeA';
const MEDIA_ARCHIVE_URL = 'https://disk.yandex.ru/d/12vg88jhsqOIpg';

const onlineSchedule = [
  {
    date: '15.07',
    time: '16:00 – 18:00',
    timeNote: 'МСК 11:00',
    track: 'Визуализация алгоритмов: от сортировок к графам',
    expert: 'Арсений Обозненко',
    focus: 'Базовый курс проектного программирования. Трансформация абстрактной логики в наглядные схемы и графовые модели.',
    joinUrl: 'https://vk.com/call/join/QFkCQMsuoI2hjlT6FcriGxOEP8fGxfhRgUjulVnRn6c',
    streamUrl: 'https://vk.com/video326435389_456239099',
  },
  {
    date: '17.07',
    time: '16:00 – 18:00',
    timeNote: 'МСК 11:00',
    track: 'Основы Frontend-разработки',
    expert: 'Виктория Миронова',
    focus: 'Интерфейсы как мост между алгоритмом и пользователем. Создание визуальной оболочки проектов.',
    joinUrl: 'https://vk.com/call/join/gcn0b0BpOeP4cxJlhec3LSFMIa_JGipMFl0fIxNLySk',
    streamUrl: 'https://vk.com/video326435389_456239100',
  },
  {
    date: '20.07',
    time: '16:00 – 18:00',
    timeNote: 'МСК 11:00',
    track: 'Использование ИИ для решения задач проектно-исследовательских работ',
    expert: 'Владислав Гребенюк',
    focus: 'Интеграция генеративного ИИ в цикл исследования: от гипотезы до выводов.',
    joinUrl: 'https://vk.com/call/join/vNP_owtI5WAM9NRavNvUa27BmUS--FQkuhXbww8Ai4A',
    streamUrl: 'https://vk.com/video326435389_456239101',
  },
  {
    date: '22.07',
    time: '16:00 – 18:00',
    timeNote: 'МСК 11:00',
    track: 'Автоматизация рутинных задач с использованием генеративного ИИ в работе учителя',
    expert: 'Александр Степанов',
    focus: 'Прикладные сценарии: генерация контента, проверка работ, адаптация материалов под ученика.',
    joinUrl: 'https://vk.com/call/join/8Bz90O5Rsinzm89oAPgIV6Tv8LlrgWyrO_g1mqcL_9w',
    streamUrl: 'https://vk.com/video326435389_456239102',
  },
  {
    date: '24.07',
    time: '16:00 – 18:00',
    timeNote: 'МСК 11:00',
    track: 'Основы проектной деятельности',
    expert: 'Пётр Зуев',
    focus: 'Системная сборка всех модулей: от замысла до реализации и защиты проекта. Методология и критерии оценки.',
    joinUrl: 'https://vk.com/call/join/7JexhmBNRowVX62kLQAkVIFQpPd0NH3C2M7bbdDdMAs',
    streamUrl: 'https://vk.com/video326435389_456239103',
  },
];
---

<Layout
  title="ТЕХНОМАТИКА — Материалы КПК"
  description="Учебные материалы очного модуля КПК «Информатика в междисциплинарных проектах: Архитектура образовательных решений». Презентационные материалы, конспекты лекций, практикумы."
  ogTitle="ТЕХНОМАТИКА: Информатика в междисциплинарных проектах"
>

  <!-- ============ HERO ============ -->
  <section class="relative bg-brand-dark text-white overflow-hidden min-h-0 sm:min-h-[480px] md:min-h-[560px] flex items-center">
    <div class="absolute right-0 top-0 bottom-0 w-2/5 sm:w-1/2 md:w-2/5 opacity-40 sm:opacity-60 pointer-events-none">
      <DiamondPattern variant="hero" />
    </div>

    <div class="absolute right-0 top-0 bottom-0 w-2/5 sm:w-1/2 md:w-2/5 bg-gradient-to-r from-brand-dark via-brand-dark/80 to-transparent pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12 md:py-28 w-full">
      <div class="max-w-2xl w-full min-w-0">
        <div class="mb-4 sm:mb-6">
          <span class="chip-green">Программа повышения квалификации для учителей информатики</span>
        </div>

        <h1 class="text-hero font-bold text-white mb-4 sm:mb-5 leading-tight">
          Информатика<br/>
          <span class="hero-nowrap">в&nbsp;междисциплинарных</span><br/>
          проектах
        </h1>

        <p class="text-base sm:text-lg text-white/70 mb-8 sm:mb-10 max-w-xl leading-relaxed">
          Все материалы — в одном месте.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4">
          <a href="#modules" class="btn-primary text-center">Перейти к материалам</a>
          <a href={MEDIA_ARCHIVE_URL} target="_blank" rel="noopener noreferrer" class="btn-outline-white text-center">Фото и видео</a>
          <a href={path('/students')} class="btn-outline-white text-center">Программа для учеников</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="relative bg-white overflow-hidden" aria-label="Программа в цифрах">
    <div class="absolute inset-0">
      <DiamondPattern variant="texture" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { value: '48', label: 'академических часов' },
          { value: '3', label: 'дня очного обучения' },
          { value: '5', label: 'модулей программы' },
          { value: '✓', label: 'Удостоверение о&nbsp;ПК' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-ink leading-none mb-2" set:html={stat.value} />
            <div class="text-sm text-muted leading-snug" set:html={stat.label} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HIGHLIGHT VIDEO ============ -->
  <section class="bg-brand-dark" aria-label="Видео с очного интенсива">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <div class="video-frame">
        <iframe
          class="video-player"
          src="https://vkvideo.ru/video_ext.php?oid=-231468147&id=456239069&hash=3127174a74979279&hd=3"
          title="Техноматика, Иркутск, июль 2026"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <DiamondPattern variant="divider" />

  <!-- ============ MODULES / MATERIALS ============ -->
  <section id="modules" class="bg-white" aria-labelledby="modules-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-20 pb-4">
      <div class="mb-10 md:mb-14 text-center">
        <span class="chip-dark mb-4 inline-block">Очный интенсив · 3 дня</span>
        <h2 id="modules-heading" class="text-h2 font-semibold text-ink">Материалы по модулям</h2>
        <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
          Три модуля очного обучения. Презентационные материалы, конспекты лекций, дополнительные и самостоятельные работы — по каждой теме.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href={ALL_MATERIALS_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-center">
            Все материалы в одном месте
          </a>
          <a href={MEDIA_ARCHIVE_URL} target="_blank" rel="noopener noreferrer" class="btn-dark text-center">
            Фото и видео
          </a>
        </div>
      </div>
    </div>

    <div id="materials" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 md:pb-24 flex flex-col gap-10 md:gap-20">
      {modules.map(mod => (
        <div>
          <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-8">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="module-number">{mod.num}</span>
                <span class="chip-dark">Модуль {mod.num}</span>
              </div>
              <h3 class="text-2xl font-semibold text-ink leading-snug">{mod.title}</h3>
              <p class="mt-2 text-muted text-sm leading-relaxed max-w-2xl">{mod.desc}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {mod.lectures.map(lecture => (
              <LectureCard
                code={lecture.data.code}
                title={lecture.data.title}
                summary={lecture.data.summary}
                practiceTitle={lecture.data.practiceTitle}
                slidesUrl={lecture.data.slidesUrl}
                transcriptUrl={lecture.data.transcriptUrl}
                transcriptLabel={lecture.data.transcriptLabel}
                materials={lecture.data.materials}
                module={lecture.data.module}
              />
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ WHAT'S NEXT ============ -->
  <section id="whats-next" class="bg-brand-dark text-white" aria-labelledby="next-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-2xl mb-14">
        <span class="chip-green mb-4 inline-block">После очного интенсива</span>
        <h2 id="next-heading" class="text-h2 font-semibold text-white">Что дальше</h2>
        <p class="mt-4 text-white/60 text-base leading-relaxed">
          Очный модуль — фундамент. Программа продолжается в двух дополнительных форматах.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white/5 border border-white/10 rounded-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="module-number-light">4</span>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-green">Онлайн-модуль</span>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Онлайн-обучение в СДО</h3>
          <p class="text-white/60 text-sm leading-relaxed">
            Продолжение в системе дистанционного обучения: закрепление навыков, самостоятельная работа с учебными материалами, проверочные задания и промежуточный контроль знаний.
          </p>
          <ul class="mt-5 flex flex-col gap-2">
            {['Видео-лекции и интерактивные задания', 'Самостоятельная проработка тем', 'Промежуточная аттестация'].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/70">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 7l3 3 6-6" stroke="#7CC142" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="module-number-light">5</span>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-green">Сопровождающий трек</span>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Поддержка и защита проекта</h3>
          <p class="text-white/60 text-sm leading-relaxed">
            Сопровождающий трек включает peer-review между участниками, консультации с экспертами и финальную защиту образовательного продукта с получением удостоверения.
          </p>
          <ul class="mt-5 flex flex-col gap-2">
            {['Взаимная экспертиза проектов (peer-review)', 'Консультации с методистами', 'Финальная защита и удостоверение о ПК'].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/70">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 7l3 3 6-6" stroke="#7CC142" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Online schedule -->
      <div id="online-schedule" class="mt-12 md:mt-16">
        <div class="mb-6 md:mb-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-green mb-2">Онлайн-блок · июль</p>
          <h3 class="text-xl md:text-2xl font-semibold text-white">Расписание онлайн-занятий</h3>
          <p class="mt-2 text-white/55 text-sm leading-relaxed">
            Время указано по Иркутску (UTC+8). Начало в 16:00 — по Москве это 11:00.
          </p>
        </div>

        <!-- Schedule table -->
        <div class="schedule-table-wrap">
          <table class="schedule-table">
            <thead>
              <tr>
                <th scope="col">Дата</th>
                <th scope="col">Время (Ирк)</th>
                <th scope="col">Трек</th>
                <th scope="col">Эксперт</th>
                <th scope="col">Ключевой фокус</th>
                <th scope="col">Ссылки</th>
              </tr>
            </thead>
            <tbody>
              {onlineSchedule.map((row) => (
                <tr>
                  <td class="schedule-col-date">{row.date}</td>
                  <td class="schedule-col-time">
                    <span class="schedule-time-main">{row.time}</span>
                    <span class="schedule-time-note">({row.timeNote})</span>
                  </td>
                  <td class="schedule-col-track">{row.track}</td>
                  <td class="schedule-col-expert">{row.expert}</td>
                  <td class="schedule-col-focus">{row.focus}</td>
                  <td class="schedule-col-links">
                    <div class="schedule-actions">
                      <a href={row.joinUrl} target="_blank" rel="noopener noreferrer" class="schedule-btn schedule-btn--join">Онлайн</a>
                      <a href={row.streamUrl} target="_blank" rel="noopener noreferrer" class="schedule-btn schedule-btn--stream">Трансляция</a>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STUDENTS CTA ============ -->
  <section class="relative bg-brand-green overflow-hidden" aria-labelledby="students-heading">
    <div class="absolute inset-0 opacity-10">
      <DiamondPattern variant="texture" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-2xl">
        <span class="chip-dark mb-5 inline-block">Дополнительное образование</span>
        <h2 id="students-heading" class="text-h2 font-semibold text-ink mb-4">Программа для школьников</h2>
        <p class="text-ink/70 text-base leading-relaxed mb-8 max-w-lg">
          Программа дополнительного образования для учеников по ключевым направлениям цифровых компетенций.
        </p>

        <div class="flex flex-wrap gap-2 mb-10">
          {[
            'Основы проектной деятельности',
            'Робототехника',
            'Программирование',
            'Веб-разработка',
            'Графический дизайн',
            'Прототипирование и моделирование',
          ].map(dir => (
            <span class="direction-chip">{dir}</span>
          ))}
        </div>

        <a href={path('/students')} class="btn-dark">Открыть программу →</a>
      </div>
    </div>
  </section>

  <!-- ============ ARCHIVES ============ -->
  <section id="archives" class="bg-white" aria-labelledby="archives-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="text-center mb-10 md:mb-12">
        <span class="chip-dark mb-4 inline-block">Архивы очного модуля</span>
        <h2 id="archives-heading" class="text-h2 font-semibold text-ink">Материалы, фото и видео</h2>
        <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
          Полный пакет материалов курса и медиаархив интенсива — в одном месте на Яндекс.Диске.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-4xl mx-auto">
        <a href={ALL_MATERIALS_URL} target="_blank" rel="noopener noreferrer" class="archive-card">
          <span class="archive-card-label">Яндекс.Диск</span>
          <h3 class="archive-card-title">Все материалы в одном месте</h3>
          <p class="archive-card-text">Презентации, раздатки и файлы по дням очного интенсива.</p>
          <span class="btn-primary archive-card-btn">Открыть архив →</span>
        </a>

        <a href={MEDIA_ARCHIVE_URL} target="_blank" rel="noopener noreferrer" class="archive-card">
          <span class="archive-card-label">Медиа</span>
          <h3 class="archive-card-title">Фото и видео в одном месте</h3>
          <p class="archive-card-text">Фотографии и видеозаписи с очного модуля в Иркутске.</p>
          <span class="btn-primary archive-card-btn">Открыть медиа →</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .text-hero {
    font-size: clamp(1.5rem, 5.8vw, 4.5rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
  }
  .hero-nowrap { white-space: nowrap; }
  .text-h2 {
    font-size: clamp(2rem, 3.5vw, 2.5rem);
    line-height: 1.2;
  }

  .chip-green {
    display: inline-block;
    max-width: 100%;
    padding: 6px 10px;
    background: #7CC142;
    color: #111312;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.35;
    border-radius: 4px;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }
  @media (min-width: 640px) {
    .chip-green {
      padding: 4px 12px;
      font-size: 12px;
      letter-spacing: 0.05em;
    }
  }
  .chip-dark {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: #111312;
    color: #FFFFFF;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .module-number {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #7CC142;
    color: #111312;
    font-size: 18px;
    font-weight: 700;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .module-number-light {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    color: #7CC142;
    font-size: 18px;
    font-weight: 700;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background: #7CC142;
    color: #111312;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: filter 0.15s;
  }
  .btn-primary:hover { filter: brightness(0.93); }
  .btn-primary:focus-visible { outline: 2px solid #7CC142; outline-offset: 3px; }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background: transparent;
    color: #FFFFFF;
    font-size: 15px;
