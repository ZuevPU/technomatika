---
import Layout from '../layouts/Layout.astro';
import DiamondPattern from '../components/DiamondPattern.astro';
import LectureCard from '../components/LectureCard.astro';
import { getCollection } from 'astro:content';
import { path } from '../utils/paths';

const allLectures = await getCollection('lectures');
const byModule = (moduleNum: number) =>
  allLectures
    .filter(l => l.data.module === moduleNum)
    .sort((a, b) => a.data.code.localeCompare(b.data.code));

const modules = [
  {
    num: 1,
    title: 'Фундаментальные основы информатики',
    desc: 'Информация, системы счисления, алгоритмика — базовая концептуальная рамка курса, без которой невозможно осознанное педагогическое проектирование цифровых решений.',
    lectures: byModule(1),
  },
  {
    num: 2,
    title: 'Методология извлечения информационных моделей',
    desc: 'Как строить модели предметных областей, структурировать знания в базах данных и превращать данные в убедительные визуальные нарративы.',
    lectures: byModule(2),
  },
  {
    num: 3,
    title: 'Педагогическое проектирование образовательного продукта',
    desc: 'Learning Experience Design, создание вовлекающего цифрового контента и современные подходы к оцениванию — от идеи до готового образовательного продукта.',
    lectures: byModule(3),
  },
];
---

<Layout
  title="ТЕХНОМАТИКА — Материалы КПК"
  description="Учебные материалы очного модуля КПК «Информатика в междисциплинарных проектах: Архитектура образовательных решений». Презентации, транскрибинги, практикумы."
  ogTitle="ТЕХНОМАТИКА: Информатика в междисциплинарных проектах"
  darkHeader={true}
>

  <!-- ============ HERO ============ -->
  <section class="relative bg-brand-dark text-white overflow-hidden min-h-[560px] flex items-center">
    <!-- Geometric pattern (right half only) -->
    <div class="absolute right-0 top-0 bottom-0 w-1/2 md:w-2/5 opacity-60">
      <DiamondPattern variant="hero" />
    </div>

    <!-- Gradient fade so pattern blends with content -->
    <div class="absolute right-0 top-0 bottom-0 w-1/2 md:w-2/5 bg-gradient-to-r from-brand-dark via-brand-dark/60 to-transparent pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 mb-6">
          <span class="chip-yellow">Повышение квалификации · 48 ак. часов</span>
        </div>

        <h1 class="text-hero font-bold text-white mb-5 leading-tight" style="letter-spacing: -0.02em;">
          Информатика<br/>
          в&nbsp;междисциплинарных<br/>
          проектах
        </h1>

        <p class="text-lg text-white/70 mb-10 max-w-xl leading-relaxed">
          Архитектура образовательных решений.<br/>
          Все материалы очного модуля — в одном месте.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="#modules"
            class="btn-primary"
          >
            Перейти к материалам
          </a>
          <a
            href={path('/students')}
            class="btn-outline-white"
          >
            Программа для учеников
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="relative bg-white overflow-hidden" aria-label="Программа в цифрах">
    <div class="absolute inset-0">
      <DiamondPattern variant="texture" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { value: '48', label: 'академических часов' },
          { value: '3', label: 'дня очного обучения' },
          { value: '5', label: 'модулей программы' },
          { value: '✓', label: 'Удостоверение о&nbsp;ПК' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-ink leading-none mb-2" set:html={stat.value} />
            <div class="text-sm text-muted leading-snug" set:html={stat.label} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <DiamondPattern variant="divider" />

  <!-- ============ MODULES / MATERIALS ============ -->
  <section id="modules" class="bg-white" aria-labelledby="modules-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-4">
      <div class="mb-14 text-center">
        <span class="chip-dark mb-4 inline-block">Очный интенсив · 3 дня</span>
        <h2 id="modules-heading" class="text-h2 font-semibold text-ink">
          Материалы по модулям
        </h2>
        <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
          Три модуля очного обучения. Презентации, транскрибинги лекций и материалы для самостоятельной работы — по каждой теме.
        </p>
      </div>
    </div>

    <div id="materials" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 flex flex-col gap-20">
      {modules.map(mod => (
        <div>
          <!-- Module header -->
          <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-8">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="module-number">{mod.num}</span>
                <span class="chip-dark">Модуль {mod.num}</span>
              </div>
              <h3 class="text-2xl font-semibold text-ink leading-snug">{mod.title}</h3>
              <p class="mt-2 text-muted text-sm leading-relaxed max-w-2xl">{mod.desc}</p>
            </div>
          </div>

          <!-- Lecture cards grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {mod.lectures.map(lecture => (
              <LectureCard
                code={lecture.data.code}
                title={lecture.data.title}
                summary={lecture.data.summary}
                duration={lecture.data.duration}
                practiceTitle={lecture.data.practiceTitle}
                slidesUrl={lecture.data.slidesUrl}
                transcriptUrl={lecture.data.transcriptUrl}
                materials={lecture.data.materials}
                module={lecture.data.module}
              />
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ WHAT'S NEXT ============ -->
  <section id="whats-next" class="bg-brand-dark text-white" aria-labelledby="next-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-2xl mb-14">
        <span class="chip-yellow mb-4 inline-block">После очного интенсива</span>
        <h2 id="next-heading" class="text-h2 font-semibold text-white">
          Что дальше
        </h2>
        <p class="mt-4 text-white/60 text-base leading-relaxed">
          Очный модуль — фундамент. Программа продолжается в двух дополнительных форматах.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Module 4 -->
        <div class="bg-white/5 border border-white/10 rounded-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="module-number-light">4</span>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-yellow">Онлайн-модуль</span>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Онлайн-обучение в СДО</h3>
          <p class="text-white/60 text-sm leading-relaxed">
            Продолжение в системе дистанционного обучения: закрепление навыков, самостоятельная работа с учебными материалами, проверочные задания и промежуточный контроль знаний.
          </p>
          <ul class="mt-5 flex flex-col gap-2">
            {['Видео-лекции и интерактивные задания', 'Самостоятельная проработка тем', 'Промежуточная аттестация'].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/70">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 7l3 3 6-6" stroke="#F5E600" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Module 5 -->
        <div class="bg-white/5 border border-white/10 rounded-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="module-number-light">5</span>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-yellow">Сопровождающий трек</span>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Поддержка и защита проекта</h3>
          <p class="text-white/60 text-sm leading-relaxed">
            Сопровождающий трек включает peer-review между участниками, консультации с экспертами и финальную защиту образовательного продукта с получением удостоверения.
          </p>
          <ul class="mt-5 flex flex-col gap-2">
            {['Взаимная экспертиза проектов (peer-review)', 'Консультации с методистами', 'Финальная защита и удостоверение о ПК'].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/70">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 7l3 3 6-6" stroke="#F5E600" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STUDENTS CTA ============ -->
  <section class="relative bg-brand-yellow overflow-hidden" aria-labelledby="students-heading">
    <div class="absolute inset-0 opacity-10">
      <DiamondPattern variant="texture" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-2xl">
        <span class="chip-dark mb-5 inline-block">Дополнительное образование</span>
        <h2 id="students-heading" class="text-h2 font-semibold text-ink mb-4">
          Программа для школьников
        </h2>
        <p class="text-ink/70 text-base leading-relaxed mb-8 max-w-lg">
          Параллельно с КПК для педагогов — программа дополнительного образования для учеников по ключевым направлениям цифровых компетенций.
        </p>

        <div class="flex flex-wrap gap-2 mb-10">
          {[
            'Основы проектной деятельности',
            'Робототехника',
            'Программирование',
            'Веб-разработка',
            'Графический дизайн',
            'Прототипирование и моделирование',
          ].map(dir => (
            <span class="direction-chip">{dir}</span>
          ))}
        </div>

        <a href={path('/students')} class="btn-dark">
          Открыть программу →
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .text-hero {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.1;
  }
  .text-h2 {
    font-size: clamp(2rem, 3.5vw, 2.5rem);
    line-height: 1.2;
  }

  .chip-yellow {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: #F5E600;
    color: #111312;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }
  .chip-dark {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: #111312;
    color: #FFFFFF;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .module-number {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #F5E600;
    color: #111312;
    font-size: 18px;
    font-weight: 700;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .module-number-light {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    color: #F5E600;
    font-size: 18px;
    font-weight: 700;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    background: #F5E600;
    color: #111312;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: filter 0.15s;
  }
  .btn-primary:hover { filter: brightness(0.93); }
  .btn-primary:focus-visible { outline: 2px solid #F5E600; outline-offset: 3px; }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    background: transparent;
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    border: 2px solid rgba(255,255,255,0.4);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn-outline-white:hover {
    border-color: rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.05);
  }
  .btn-outline-white:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    background: #111312;
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-dark:hover { opacity: 0.85; }
  .btn-dark:focus-visible { outline: 2px solid #111312; outline-offset: 3px; }

  .direction-chip {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    background: rgba(17,19,18,0.08);
    color: #111312;
    font-size: 13px;
    font-weight: 500;
    border-radius: 100px;
  }
</style>
