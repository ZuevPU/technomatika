---
interface Props {
  variant?: 'hero' | 'divider' | 'texture';
  class?: string;
}
const { variant = 'hero', class: className = '' } = Astro.props;
---

{variant === 'hero' && (
  <div class:list={['arrow-pattern-hero', className]} aria-hidden="true">
    <svg width="100%" height="100%" viewBox="0 0 480 480" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <!-- Row 1 (y=15) -->
      <polygon points="0,15 45,45 0,75" fill="#7CC142" opacity="0.9"/>
      <polygon points="80,15 125,45 80,75" fill="#FFFFFF" opacity="0.06"/>
      <polygon points="160,15 205,45 160,75" fill="#7CC142" opacity="0.55"/>
      <polygon points="240,15 285,45 240,75" fill="#FFFFFF" opacity="0.05"/>
      <polygon points="320,15 365,45 320,75" fill="#7CC142" opacity="0.35"/>
      <polygon points="400,15 445,45 400,75" fill="#FFFFFF" opacity="0.07"/>
      <!-- Row 2 (y=90, offset +40) -->
      <polygon points="40,90 85,120 40,150" fill="#7CC142" opacity="0.7"/>
      <polygon points="120,90 165,120 120,150" fill="#FFFFFF" opacity="0.04"/>
      <polygon points="200,90 245,120 200,150" fill="#7CC142" opacity="0.85"/>
      <polygon points="280,90 325,120 280,150" fill="#7CC142" opacity="0.5"/>
      <polygon points="360,90 405,120 360,150" fill="#7CC142" opacity="0.25"/>
      <polygon points="440,90 485,120 440,150" fill="#FFFFFF" opacity="0.06"/>
      <!-- Row 3 (y=165) -->
      <polygon points="0,165 45,195 0,225" fill="#7CC142" opacity="0.4"/>
      <polygon points="80,165 125,195 80,225" fill="#FFFFFF" opacity="0.05"/>
      <polygon points="160,165 205,195 160,225" fill="#7CC142" opacity="1"/>
      <polygon points="240,165 285,195 240,225" fill="#FFFFFF" opacity="0.06"/>
      <polygon points="320,165 365,195 320,225" fill="#7CC142" opacity="0.6"/>
      <polygon points="400,165 445,195 400,225" fill="#7CC142" opacity="0.15"/>
      <!-- Row 4 (y=240, offset) -->
      <polygon points="40,240 85,270 40,300" fill="#7CC142" opacity="0.2"/>
      <polygon points="120,240 165,270 120,300" fill="#FFFFFF" opacity="0.03"/>
      <polygon points="200,240 245,270 200,300" fill="#7CC142" opacity="0.55"/>
      <polygon points="280,240 325,270 280,300" fill="#FFFFFF" opacity="0.05"/>
      <polygon points="360,240 405,270 360,300" fill="#7CC142" opacity="0.35"/>
      <!-- Row 5 (y=315) -->
      <polygon points="0,315 45,345 0,375" fill="#FFFFFF" opacity="0.05"/>
      <polygon points="80,315 125,345 80,375" fill="#7CC142" opacity="0.75"/>
      <polygon points="160,315 205,345 160,375" fill="#FFFFFF" opacity="0.03"/>
      <polygon points="240,315 285,345 240,375" fill="#7CC142" opacity="0.45"/>
      <polygon points="320,315 365,345 320,375" fill="#FFFFFF" opacity="0.05"/>
      <polygon points="400,315 445,345 400,375" fill="#7CC142" opacity="0.8"/>
      <!-- Row 6 (y=390, offset) -->
      <polygon points="40,390 85,420 40,450" fill="#7CC142" opacity="0.3"/>
      <polygon points="120,390 165,420 120,450" fill="#7CC142" opacity="0.65"/>
      <polygon points="200,390 245,420 200,450" fill="#FFFFFF" opacity="0.04"/>
      <polygon points="280,390 325,420 280,450" fill="#7CC142" opacity="0.5"/>
      <polygon points="360,390 405,420 360,450" fill="#7CC142" opacity="0.2"/>
      <polygon points="440,390 485,420 440,450" fill="#7CC142" opacity="0.4"/>
    </svg>
  </div>
)}

{variant === 'texture' && (
  <div class:list={['arrow-pattern-texture pointer-events-none select-none', className]} aria-hidden="true">
    <svg width="100%" height="100%" viewBox="0 0 320 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <!-- Row 1 -->
      <polygon points="-5,8 25,26 -5,44" fill="#111312" opacity="0.04"/>
      <polygon points="45,8 75,26 45,44" fill="#111312" opacity="0.025"/>
      <polygon points="95,8 125,26 95,44" fill="#111312" opacity="0.04"/>
      <polygon points="145,8 175,26 145,44" fill="#111312" opacity="0.025"/>
      <polygon points="195,8 225,26 195,44" fill="#111312" opacity="0.04"/>
      <polygon points="245,8 275,26 245,44" fill="#111312" opacity="0.025"/>
      <polygon points="295,8 325,26 295,44" fill="#111312" opacity="0.04"/>
      <!-- Row 2 (offset +25) -->
      <polygon points="20,58 50,76 20,94" fill="#111312" opacity="0.025"/>
      <polygon points="70,58 100,76 70,94" fill="#111312" opacity="0.04"/>
      <polygon points="120,58 150,76 120,94" fill="#111312" opacity="0.025"/>
      <polygon points="170,58 200,76 170,94" fill="#111312" opacity="0.04"/>
      <polygon points="220,58 250,76 220,94" fill="#111312" opacity="0.025"/>
      <polygon points="270,58 300,76 270,94" fill="#111312" opacity="0.04"/>
      <!-- Row 3 -->
      <polygon points="-5,108 25,126 -5,144" fill="#111312" opacity="0.04"/>
      <polygon points="45,108 75,126 45,144" fill="#111312" opacity="0.025"/>
      <polygon points="95,108 125,126 95,144" fill="#111312" opacity="0.04"/>
      <polygon points="145,108 175,126 145,144" fill="#111312" opacity="0.025"/>
      <polygon points="195,108 225,126 195,144" fill="#111312" opacity="0.04"/>
      <polygon points="245,108 275,126 245,144" fill="#111312" opacity="0.025"/>
      <polygon points="295,108 325,126 295,144" fill="#111312" opacity="0.04"/>
    </svg>
  </div>
)}

{variant === 'divider' && (
  <div class:list={['arrow-divider', className]} aria-hidden="true">
    <svg width="100%" height="32" viewBox="0 0 1200 32" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,4 65,16 0,28" fill="#7CC142"/>
      <polygon points="80,4 145,16 80,28" fill="#111312"/>
      <polygon points="160,4 225,16 160,28" fill="#7CC142"/>
      <polygon points="240,4 305,16 240,28" fill="#111312"/>
      <polygon points="320,4 385,16 320,28" fill="#7CC142"/>
      <polygon points="400,4 465,16 400,28" fill="#111312"/>
      <polygon points="480,4 545,16 480,28" fill="#7CC142"/>
      <polygon points="560,4 625,16 560,28" fill="#111312"/>
      <polygon points="640,4 705,16 640,28" fill="#7CC142"/>
      <polygon points="720,4 785,16 720,28" fill="#111312"/>
      <polygon points="800,4 865,16 800,28" fill="#7CC142"/>
      <polygon points="880,4 945,16 880,28" fill="#111312"/>
      <polygon points="960,4 1025,16 960,28" fill="#7CC142"/>
      <polygon points="1040,4 1105,16 1040,28" fill="#111312"/>
      <polygon points="1120,4 1185,16 1120,28" fill="#7CC142"/>
      <polygon points="1200,4 1265,16 1200,28" fill="#111312"/>
    </svg>
  </div>
)}

<style>
  .arrow-pattern-hero {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .arrow-pattern-texture {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .arrow-divider {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
</style>
