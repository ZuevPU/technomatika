---
interface Props {
  variant?: 'hero' | 'divider' | 'texture';
  class?: string;
}
const { variant = 'hero', class: className = '' } = Astro.props;
---

{variant === 'hero' && (
  <div class:list={['diamond-pattern-hero', className]} aria-hidden="true">
    <svg width="100%" height="100%" viewBox="0 0 480 480" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <!-- Row 1 -->
      <rect x="-20" y="20" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.9"/>
      <rect x="90" y="20" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.08"/>
      <rect x="200" y="20" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.5"/>
      <rect x="310" y="20" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.05"/>
      <rect x="420" y="20" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.3"/>
      <!-- Row 2 (offset) -->
      <rect x="-65" y="110" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.06"/>
      <rect x="45" y="110" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.7"/>
      <rect x="155" y="110" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.04"/>
      <rect x="265" y="110" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.85"/>
      <rect x="375" y="110" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.06"/>
      <!-- Row 3 -->
      <rect x="-20" y="200" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.4"/>
      <rect x="90" y="200" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.05"/>
      <rect x="200" y="200" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="1"/>
      <rect x="310" y="200" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.07"/>
      <rect x="420" y="200" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.6"/>
      <!-- Row 4 (offset) -->
      <rect x="-65" y="290" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.2"/>
      <rect x="45" y="290" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.04"/>
      <rect x="155" y="290" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.55"/>
      <rect x="265" y="290" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.06"/>
      <rect x="375" y="290" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.35"/>
      <!-- Row 5 -->
      <rect x="-20" y="380" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.05"/>
      <rect x="90" y="380" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.75"/>
      <rect x="200" y="380" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.03"/>
      <rect x="310" y="380" width="90" height="70" transform="skewX(-20)" fill="#F5E600" opacity="0.45"/>
      <rect x="420" y="380" width="90" height="70" transform="skewX(-20)" fill="#FFFFFF" opacity="0.06"/>
    </svg>
  </div>
)}

{variant === 'texture' && (
  <div class:list={['diamond-pattern-texture pointer-events-none select-none', className]} aria-hidden="true">
    <svg width="100%" height="100%" viewBox="0 0 320 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <rect x="-10" y="10" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="60" y="10" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="130" y="10" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="200" y="10" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="270" y="10" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="-40" y="64" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="30" y="64" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="100" y="64" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="170" y="64" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="240" y="64" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="-10" y="118" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="60" y="118" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="130" y="118" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
      <rect x="200" y="118" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.025"/>
      <rect x="270" y="118" width="60" height="44" transform="skewX(-20)" fill="#111312" opacity="0.04"/>
    </svg>
  </div>
)}

{variant === 'divider' && (
  <div class:list={['diamond-divider', className]} aria-hidden="true">
    <svg width="100%" height="32" viewBox="0 0 1200 32" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="-10" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
      <rect x="100" y="4" width="100" height="24" transform="skewX(-20)" fill="#111312"/>
      <rect x="200" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
      <rect x="300" y="4" width="100" height="24" transform="skewX(-20)" fill="#111312"/>
      <rect x="400" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
      <rect x="500" y="4" width="100" height="24" transform="skewX(-20)" fill="#111312"/>
      <rect x="600" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
      <rect x="700" y="4" width="100" height="24" transform="skewX(-20)" fill="#111312"/>
      <rect x="800" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
      <rect x="900" y="4" width="100" height="24" transform="skewX(-20)" fill="#111312"/>
      <rect x="1000" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
      <rect x="1100" y="4" width="100" height="24" transform="skewX(-20)" fill="#111312"/>
      <rect x="1200" y="4" width="100" height="24" transform="skewX(-20)" fill="#F5E600"/>
    </svg>
  </div>
)}

<style>
  .diamond-pattern-hero {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .diamond-pattern-texture {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .diamond-divider {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
</style>
