---
import Logo from './Logo.astro';
import { path } from '../utils/paths';

const ALL_MATERIALS_URL = 'https://disk.yandex.ru/d/Qv6znPxKL8uxeA';
const MEDIA_ARCHIVE_URL = 'https://disk.yandex.ru/d/12vg88jhsqOIpg';
---

<header class="sticky top-0 z-50 backdrop-blur-sm border-b border-white/10 bg-brand-dark/95 transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 md:h-16 flex items-center justify-between gap-6">
    <Logo />

    <!-- Desktop nav only — mobile uses bottom tab bar -->
    <nav class="hidden md:flex items-center gap-5 lg:gap-6" aria-label="Основная навигация">
      <a href={path('/#modules')} class="text-sm font-medium transition-colors text-white/80 hover:text-white">
        Программа
      </a>
      <a href={path('/#materials')} class="text-sm font-medium transition-colors text-white/80 hover:text-white">
        Материалы
      </a>
      <a
        href={ALL_MATERIALS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium transition-colors text-white/80 hover:text-white"
      >
        Все материалы
      </a>
      <a
        href={MEDIA_ARCHIVE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium transition-colors text-white/80 hover:text-white"
      >
        Фото и видео
      </a>
      <a href={path('/#whats-next')} class="text-sm font-medium transition-colors text-white/80 hover:text-white">
        Что дальше
      </a>
      <a href={path('/#online-schedule')} class="text-sm font-medium transition-colors text-white/80 hover:text-white">
        Онлайн
      </a>
      <a
        href={path('/students')}
        class="text-sm font-semibold px-4 py-2 rounded-lg border-2 border-brand-green text-brand-green hover:bg-brand-green hover:text-ink transition-colors"
      >
        Ученикам →
      </a>
    </nav>
  </div>
</header>
