---
import { path } from '../utils/paths';

interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---
<a href={path('/')} class="flex items-center no-underline group" aria-label="Техноматика — на главную">
  <img
    src={path('/TM_View.png')}
    alt="техноматика"
    height="40"
    class="h-10 w-auto object-contain transition-opacity group-hover:opacity-80"
    loading="eager"
  />
</a>
