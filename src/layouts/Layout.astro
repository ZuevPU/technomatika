---
import '@fontsource/inter/cyrillic-400.css';
import '@fontsource/inter/cyrillic-500.css';
import '@fontsource/inter/cyrillic-600.css';
import '@fontsource/inter/cyrillic-700.css';
import '@fontsource/inter/latin-400.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import { path } from '../utils/paths';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  noFooter?: boolean;
}

const {
  title,
  description = 'Учебные материалы программы повышения квалификации «Информатика в междисциплинарных проектах: Архитектура образовательных решений». Бренд ТЕХНОМАТИКА.',
  ogTitle,
  noFooter = false,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL('https://mashukOnline.gitverse.site');
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL(path('/TM_View.png'), siteOrigin).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <!-- MAX Mini App SDK -->
    <script is:inline src="https://st.max.ru/js/max-web-app.js"></script>
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${path('/favicon.svg')}?v=2`} />
    <link rel="apple-touch-icon" href={path('/TM_View.png')} />
    <meta name="theme-color" content="#111312" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ru_RU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-brand-white font-sans text-ink antialiased">
    <a href="#main-content" class="skip-link">Перейти к содержанию</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    {!noFooter && <Footer />}
    <BottomNav />

    <!-- Yandex.Metrika — только вне MAX WebView (в MAX блокируется и не нужна) -->
    <script is:inline>
      (function () {
        var isMaxMiniApp =
          typeof window.WebApp !== 'undefined' || /max\.ru/i.test(document.referrer);

        if (isMaxMiniApp) return;

        (function (m, e, t, r, i, k, a) {
          m[i] =
            m[i] ||
            function () {
              (m[i].a = m[i].a || []).push(arguments);
            };
          m[i].l = 1 * new Date();
          for (var j = 0; j < document.scripts.length; j++) {
            if (document.scripts[j].src === r) {
              return;
            }
          }
          k = e.createElement(t);
          a = e.getElementsByTagName(t)[0];
          k.async = 1;
          k.src = r;
          a.parentNode.insertBefore(k, a);
        })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=110085227', 'ym');

        ym(110085227, 'init', {
          clickmap: true,
          trackLinks: true,
          accurateTrackBounce: true,
        });
      })();
    </script>
    <noscript>
      <div><img src="https://mc.yandex.ru/watch/110085227" style="position:absolute; left:-9999px;" alt="" /></div>
    </noscript>
  </body>

  <script is:inline>
    function initMaxWebApp() {
      if (window.WebApp) {
        window.WebApp.ready();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMaxWebApp);
    } else {
      initMaxWebApp();
    }
  </script>
</html>

<style is:global>
  :root {
    --brand-green: #7CC142;
    --brand-dark: #111312;
    --brand-white: #FFFFFF;
    --ink: #111312;
    --muted: #6B6F6E;
    --line: #E6E6E3;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    overflow-x: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: var(--brand-green);
    color: var(--ink);
    font-weight: 600;
    border-radius: 0 0 8px 8px;
    text-decoration: none;
    transition: top 0.15s;
  }
  .skip-link:focus {
    top: 0;
  }

  :focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  /* Touch — remove 300ms tap delay everywhere */
  a, button, [role="button"] {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  /* Mobile: pad body so content isn't hidden under the fixed bottom nav */
  @media (max-width: 767px) {
    body {
      padding-bottom: calc(60px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
